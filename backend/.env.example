# Database
DATABASE_URL=sqlite:///./tnpsc.db
# For PostgreSQL: postgresql://user:password@host:5432/tnpsc_db
# For Supabase: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# Security
SECRET_KEY=your-super-secret-key-minimum-32-chars-change-this

# Admin credentials (created on startup)
ADMIN_EMAIL=admin@yoursite.com
ADMIN_PASS=YourStrongPassword@123

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-app-password-here
FROM_EMAIL=your.email@gmail.com
FROM_NAME=TNPSC Mock Test Platform

# CORS
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
